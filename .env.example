# Copy this file to .env and fill in your values.
# .env is excluded from GitHub via .gitignore — never commit .env

# Path to your downloaded Google OAuth credential JSON file
# Example: /Users/yourname/secrets/willcrest-credentials.json
GOOGLE_CREDENTIALS_PATH=

# The Gmail address you are sending FROM
SENDER_EMAIL=clark@willcrestpartners.com

# Maximum emails allowed per day (safety cap)
DAILY_SEND_LIMIT=20

# Optional: comma-separated list of allowed recipient domains
# Leave blank to allow any recipient
# Example: willcrestpartners.com,gmail.com
ALLOWED_RECIPIENT_DOMAINS=
