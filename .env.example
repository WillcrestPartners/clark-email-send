# Copy this file to .env and fill in your values.
# .env is excluded from GitHub via .gitignore — never commit .env
# On Railway (or your hosting platform), set these as environment variables
# in the platform's dashboard instead of using a .env file.

# The Gmail address you are sending FROM
SENDER_EMAIL=clark@willcrestpartners.com

# Google Service Account credentials
# Option A (recommended for servers): paste the entire JSON key file contents
GOOGLE_SERVICE_ACCOUNT_JSON=

# Option B (local development only): path to the JSON key file on your computer
# GOOGLE_SERVICE_ACCOUNT_PATH=/path/to/service-account-key.json

# Default daily send limit per user (can be overridden per user in config.json)
DEFAULT_DAILY_LIMIT=20

# Port for the MCP server to listen on (Railway sets this automatically)
PORT=8000

# ── Inbound email command bus (Phase 1) ────────────────────────────────────
# Shared HMAC secret with the Clark destination. Signs every inbound POST and
# verifies the inbound /send relay. Must match Clark's CLARK_INBOUND_HMAC_SECRET.
CLARK_INBOUND_HMAC_SECRET=

# Clark inbound webhook — the gateway POSTs the envelope here.
# (May instead be set per-mailbox in config.json's inbound.mailboxes[].destination.)
CLARK_WEBHOOK_URL=https://clark-host/api/email/inbound

# Clark authorized-sender allow-list — the gateway GETs this (signed empty body).
CLARK_AUTHORIZED_SENDERS_URL=https://clark-host/api/email/authorized-senders

# SQLite path for inbound idempotency / audit bookkeeping.
INBOUND_DB_PATH=/app/inbound.db

# Optional: TTL (seconds) for caching the authorized-sender list (default 300).
# CLARK_SENDERS_TTL=300

# NOTE: the gmail.readonly scope
# (https://www.googleapis.com/auth/gmail.readonly) MUST be added to the
# service account's Domain-wide Delegation scopes in Google Workspace Admin
# for inbound polling to read mail. The gateway holds NO Anthropic key — all
# intent classification happens in Clark.
